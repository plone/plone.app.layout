<tal:favicon define="
               url python: view.favicon_path;
             ">
  <link as="image"
        href="${url}"
        rel="preload"
        type="${python: view.mimetype}"
  />
  <link href="${url}"
        rel="icon"
        type="${python: view.mimetype}"
  />
  <link href="${url}"
        rel="mask-icon"
  />
</tal:favicon>
